rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * RIZERWEBNP SECURITY RULES
     * 
     * CORE PHILOSOPHY:
     * This ruleset implements a strict authorization model centered around user ownership and 
     * administrative overrides. It prioritizes Authorization Independence by ensuring that 
     * security decisions can be made using only the information available in the request 
     * path or the document itself, minimizing the need for expensive cross-document lookups.
     *
     * DATA STRUCTURE:
     * - /users/{userId}: Private user profiles, accessible only by the owner.
     * - /users/{userId}/website_requests/{requestId}: Private project requests submitted by 
     *   authenticated users. Access is granted to the owner and administrators.
     * - /website_types/{typeId}: Publicly readable catalog of services. Writes are admin-only.
     * - /anonymous_website_requests/{requestId}: Submissions from non-logged-in users, 
     *   accessible only by administrators for processing.
     * - /roles_admin/{userId}: A marker collection used to identify users with global 
     *   administrative privileges.
     *
     * KEY SECURITY DECISIONS:
     * 1. User Privacy: Listing the top-level /users collection is strictly forbidden.
     * 2. Administrative Access: Admin status is determined by the existence of a document 
     *    matching the user's UID in the 'roles_admin' collection.
     * 3. Relational Integrity: For user-owned data, rules enforce that the internal 
     *    ownership field (e.g., userId) remains consistent with the document path and 
     *    is immutable after creation.
     * 4. Denormalization: Critical identifiers like 'userId' are required to be present 
     *    on documents to allow for fast, non-recursive security checks.
     */

    // --- Helper Functions ---

    /** @description Checks if the user is authenticated. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** @description Checks if the authenticated user's UID matches the provided userId. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** @description Checks if the user is a registered owner and the document exists. */
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    /** @description Checks if the authenticated user has administrative privileges. */
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    // --- Collection Rules ---

    /**
     * @description Rules for user profile documents. Ensures users can only manage their own profiles.
     * @path /users/{userId}
     * @allow (get) request.auth.uid == "user_123" accessing /users/user_123
     * @deny (list) any user attempting to list all profiles.
     * @principle Ownership-based access and self-creation validation.
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId);
      
      /**
       * @description Rules for website requests linked to a specific user.
       * @path /users/{userId}/website_requests/{websiteRequestId}
       * @allow (list) request.auth.uid == "user_123" listing their own requests.
       * @deny (create) request.auth.uid == "user_123" creating a request with userId "user_456".
       * @principle Path-based authorization with administrative override.
       */
      match /website_requests/{websiteRequestId} {
        allow get, list: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if (isExistingOwner(userId) || isAdmin()) && request.resource.data.userId == resource.data.userId;
        allow delete: if isExistingOwner(userId) || isAdmin();
      }
    }

    /**
     * @description Rules for the website types catalog.
     * @path /website_types/{websiteTypeId}
     * @allow (get) Any anonymous visitor reading a website type definition.
     * @deny (update) A non-admin user attempting to change prices.
     * @principle Public read-only access with restricted administrative writes.
     */
    match /website_types/{websiteTypeId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description Rules for anonymous website requests.
     * @path /anonymous_website_requests/{websiteRequestId}
     * @allow (get) An admin user reviewing an anonymous submission.
     * @deny (create) An anonymous user attempting to submit if the IR restricts to admins.
     * @principle Admin-only processing area for non-attributed data.
     */
    match /anonymous_website_requests/{websiteRequestId} {
      // NOTE: IR reasoning states access is strictly limited to administrators.
      allow get, list, create, update, delete: if isAdmin();
    }

    /**
     * @description Rules for the admin roles marker collection.
     * @path /roles_admin/{userId}
     * @allow (get) Any signed-in user checking their own or others' admin status.
     * @deny (create) A user attempting to grant themselves admin rights.
     * @principle Immutable role assignments managed outside of standard client logic.
     */
    match /roles_admin/{userId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create, update, delete: if false; 
    }
  }
}

// Prototyping Mode: Logic focuses on Identity and Ownership. 
// Field-level schema validation is omitted to allow rapid data shape iteration.

/*
 * HELP:
 * For 'WebsiteRequest' under '/users/{userId}', we enforce that 'userId' in the data matches the path.
 * For 'WebsiteRequest' under '/anonymous_website_requests', only admins have access per IR reasoning.
 * For 'WebsiteType', we allow public reads but restrict all writes to verified administrators.
 */

/*
 * CRITICAL: The pattern 'Public Read with Owner-Only Writes' was evaluated for 'WebsiteType'.
 * Since 'WebsiteType' is a global catalog and not user-authored content, 
 * it correctly defaults to Admin-Only writes.
 */