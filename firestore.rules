rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helpers ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    // --- Public Access Collections (Updated v20) ---

    match /announcements/{announcementId} {
      // Allow everyone to read current announcements
      allow read: if true;
      allow write: if isAdmin();
    }

    match /reviews/{reviewId} {
      // Allow everyone to read approved reviews
      allow read: if true;
      // Allow logged in users to post reviews
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    match /website_types/{typeId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // --- User Specific Collections ---

    match /users/{userId} {
      allow get, create, update: if isOwner(userId);
      
      match /website_requests/{requestId} {
        allow read, create, update, delete: if isOwner(userId) || isAdmin();
      }
    }

    // --- Admin & Support Collections ---

    match /requests/{requestId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    match /anonymous_website_requests/{requestId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    match /roles_admin/{userId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow write: if isAdmin();
    }
  }
}
