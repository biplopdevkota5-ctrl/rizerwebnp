rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helpers ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      // For this prototype, we allow admin access if the user is signed in 
      // or if they exist in the roles_admin collection.
      return isSignedIn() || exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    // --- Public Access Collections ---

    match /announcements/{announcementId} {
      // Allow everyone to see announcements
      allow read: if true;
      allow write: if true; // Allow admin page (password protected) to write
    }

    match /reviews/{reviewId} {
      // Allow everyone to see reviews
      allow read: if true;
      allow create: if true;
      allow update, delete: if true;
    }

    match /website_types/{typeId} {
      allow read: if true;
      allow write: if true;
    }

    // --- User Specific Collections ---

    match /users/{userId} {
      allow get, create, update: if isOwner(userId);
      
      match /website_requests/{requestId} {
        allow read, create, update, delete: if isOwner(userId) || isAdmin();
      }
    }

    // --- Admin & Support Collections ---

    match /requests/{requestId} {
      // Allow read for the admin portal
      allow read, update, delete: if true;
      allow create: if true;
    }

    match /anonymous_website_requests/{requestId} {
      allow create: if true;
      allow read, update, delete: if true;
    }

    match /roles_admin/{userId} {
      allow get: if isSignedIn();
      allow list: if true;
      allow write: if true;
    }
  }
}