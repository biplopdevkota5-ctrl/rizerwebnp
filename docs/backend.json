
{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a registered user of the RIZER WEB APP platform.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "email", "createdAt"]
    },
    "WebsiteType": {
      "title": "WebsiteType",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "startingPrice": { "type": "number" },
        "imageUrl": { "type": "string", "format": "uri" }
      },
      "required": ["id", "name", "description", "startingPrice"]
    },
    "WebsiteRequest": {
      "title": "WebsiteRequest",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "fullName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phoneNumber": { "type": "string" },
        "websiteTypeId": { "type": "string" },
        "budgetAmount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "processing", "completed", "cancelled"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "fullName", "email", "status", "createdAt"]
    },
    "Announcement": {
      "title": "Announcement",
      "type": "object",
      "properties": {
        "content": { "type": "string" },
        "isActive": { "type": "boolean" },
        "type": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["content", "isActive", "createdAt"]
    },
    "Review": {
      "title": "Review",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "text": { "type": "string" },
        "rating": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "text", "rating", "status", "createdAt"]
    }
  },
  "auth": {
    "providers": ["password", "anonymous", "google.com"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/backend/entities/User" },
      "description": "User profiles."
    },
    "/website_types/{websiteTypeId}": {
      "schema": { "$ref": "#/backend/entities/WebsiteType" },
      "description": "Website categories."
    },
    "/users/{userId}/website_requests/{websiteRequestId}": {
      "schema": { "$ref": "#/backend/entities/WebsiteRequest" },
      "description": "User specific build requests."
    },
    "/anonymous_website_requests/{websiteRequestId}": {
      "schema": { "$ref": "#/backend/entities/WebsiteRequest" },
      "description": "Guest build requests."
    },
    "/announcements/{announcementId}": {
      "schema": { "$ref": "#/backend/entities/Announcement" },
      "description": "Global home announcements."
    },
    "/reviews/{reviewId}": {
      "schema": { "$ref": "#/backend/entities/Review" },
      "description": "Client testimonials."
    },
    "/requests/{requestId}": {
      "schema": { "$ref": "#/backend/entities/WebsiteRequest" },
      "description": "Admin requests view."
    },
    "/roles_admin/{userId}": {
      "schema": { "$ref": "#/backend/entities/User" },
      "description": "Admin role assignments."
    }
  }
}
