{
  "entities": {
    "User": {
      "title": "User",
      "description": "Represents a registered user.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "email", "createdAt"]
    },
    "WebsiteRequest": {
      "title": "WebsiteRequest",
      "description": "A request for a website build.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "fullName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "websiteType": { "type": "string" },
        "budget": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "processing", "completed", "cancelled"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "fullName", "email", "status", "createdAt"]
    },
    "Announcement": {
      "title": "Announcement",
      "description": "Global home announcements.",
      "type": "object",
      "properties": {
        "content": { "type": "string" },
        "isActive": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["content", "isActive", "createdAt"]
    },
    "Review": {
      "title": "Review",
      "description": "Client testimonials.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "text": { "type": "string" },
        "rating": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "text", "rating", "status", "createdAt"]
    }
  },
  "auth": {
    "providers": ["password", "google.com", "anonymous"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles."
    },
    "/announcements/{announcementId}": {
      "schema": "Announcement",
      "description": "Global announcements."
    },
    "/reviews/{reviewId}": {
      "schema": "Review",
      "description": "Client reviews."
    },
    "/users/{userId}/website_requests/{requestId}": {
      "schema": "WebsiteRequest",
      "description": "User specific requests."
    },
    "/requests/{requestId}": {
      "schema": "WebsiteRequest",
      "description": "All requests for admin view."
    },
    "/roles_admin/{userId}": {
      "schema": "User",
      "description": "Admin role markers."
    }
  }
}